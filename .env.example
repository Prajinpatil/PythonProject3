# ========================================
# Surveillance Intelligence System
# Environment Configuration Template
# ========================================

# ========== APPLICATION ==========
APP_NAME=Surveillance Intelligence System
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true

# ========== SECURITY ==========
# CRITICAL: Generate new secret key for production!
# Use: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ========== DATABASE ==========
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./surveillance.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/surveillance

DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ========== CORS ==========
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true

# ========== RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ========== THREAT DETECTION ==========
THREAT_SCORE_THRESHOLD_CRITICAL=80
THREAT_SCORE_THRESHOLD_HIGH=60
THREAT_SCORE_THRESHOLD_MEDIUM=40
PATTERN_DETECTION_ENABLED=true
PATTERN_TIME_WINDOW_MINUTES=30
PATTERN_MIN_EVENTS=3

# ========== ANALYTICS ==========
ANALYTICS_ENABLED=true
ANALYTICS_CACHE_TTL_SECONDS=300
EVENT_RETENTION_DAYS=90

# ========== NOTIFICATIONS ==========
NOTIFICATION_ENABLED=true
ALERT_COOLDOWN_SECONDS=300

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=alerts@surveillance.com

# Webhook (Optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
WEBHOOK_TIMEOUT=10

# ========== LOGGING ==========
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=surveillance.log

# ========== API DOCUMENTATION ==========
DOCS_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# ========== FILE UPLOAD ==========
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".mp4"]
